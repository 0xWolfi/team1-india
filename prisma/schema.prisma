generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id           String    @id @default(uuid())
  email        String    @unique
  xHandle      String?
  name         String?
  image        String?
  permissions  Json?     @default("{\"default\": \"READ\"}")
  tags         String[]  @default([])
  status       String // applied, approved, active, paused
  customFields Json?     @default("{}")
  notificationPreferences Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  deletedAt    DateTime?

  // Relations
  lockedPlaybooks    Playbook[]          @relation("LockedBy")
  createdPlaybooks   Playbook[]          @relation("CreatedBy")
  assignedOperations Operation[]
  createdMedia       MediaItem[]
  experiments        Experiment[]
  comments           ExperimentComment[]
  mediaComments      Comment[]
  logs               Log[]

  auditLogs        AuditLog[]
  contentResources ContentResource[]
  createdProjects  Project[]
  createdPartners  Partner[]
  guides           Guide[]

  @@index([status])
  @@index([xHandle])
  @@index([deletedAt])
  @@index([status, deletedAt])
}

model CommunityMember {
  id           String    @id @default(uuid())
  email        String    @unique
  xHandle      String?
  telegram     String?
  name         String?
  tags         String?   @default("member") // e.g. "Founder", "Investor"
  status       String    @default("active")
  customFields Json?     @default("{}")
  notificationPreferences Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  deletedAt    DateTime?

  @@index([status])
  @@index([xHandle])
  @@index([deletedAt])
  @@index([status, deletedAt])
}

model Playbook {
  id             String     @id @default(uuid())
  title          String
  body           Json
  markdownExport String?
  status         String? // draft, pending, approved, published
  visibility     Visibility @default(CORE)
  coverImage     String?
  description    String?
  tags           String[]
  version        Int        @default(1)
  createdAt      DateTime   @default(now())
  deletedAt      DateTime?

  // Relations
  lockedBy    Member?   @relation("LockedBy", fields: [lockedById], references: [id])
  lockedById  String?
  lockedAt    DateTime?
  updatedAt   DateTime  @default(now()) @updatedAt
  createdBy   Member?   @relation("CreatedBy", fields: [createdById], references: [id])
  createdById String?

  @@index([status])
  @@index([visibility])
  @@index([deletedAt])
  @@index([status, deletedAt])
}

model Operation {
  id              String    @id @default(uuid())
  title           String?
  type            String? // task, meeting
  status          String?
  dueDate         DateTime?
  relatedType     String?
  relatedId       String?
  timeEstimate    Int?
  timeLogged      Int?
  calendarEventId String?
  links           String[]
  createdAt       DateTime  @default(now())
  deletedAt       DateTime?

  assignee   Member? @relation(fields: [assigneeId], references: [id])
  assigneeId String?

  @@index([status])
  @@index([type])
  @@index([assigneeId])
  @@index([deletedAt])
  @@index([status, deletedAt])
}

model MediaItem {
  id          String    @id @default(uuid())
  title       String?
  description String?
  platform    String[]
  links       String[]
  status      String? // draft, needs_edit, pending_approval, approved, posted
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  createdBy   Member?     @relation(fields: [createdById], references: [id])
  createdById String?
  posts       MediaPost[]
  comments    Comment[]
  auditLogs   AuditLog[]

  @@index([status])
  @@index([createdById])
  @@index([deletedAt])
  @@index([status, deletedAt])
}

model MediaPost {
  id        String    @id @default(uuid())
  postUrl   String?
  postedAt  DateTime?
  deletedAt DateTime?

  media   MediaItem @relation(fields: [mediaId], references: [id])
  mediaId String
}

model Comment {
  id        String    @id @default(uuid())
  content   String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  media   MediaItem @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId String

  author   Member @relation(fields: [authorId], references: [id])
  authorId String

  @@index([mediaId])
  @@index([deletedAt])
}

enum Visibility {
  CORE
  MEMBER
  PUBLIC
}

model Guide {
  id                   String     @id @default(uuid())
  type                 String? // event, program, content
  title                String?
  coverImage           String?
  body                 Json?
  audience             String[]   @default([])
  formSchema           Json?
  visibility           Visibility @default(CORE)
  maxSubmissionsPublic Int?       @default(1)
  maxSubmissionsMember Int?       @default(10)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @default(now()) @updatedAt
  deletedAt            DateTime?

  createdBy   Member? @relation(fields: [createdById], references: [id])
  createdById String?

  applications Application[]

  @@index([type])
  @@index([visibility])
  @@index([deletedAt])
}

model Application {
  id             String    @id @default(uuid())
  applicantEmail String?
  data           Json?
  status         String?
  submittedAt    DateTime  @default(now())
  deletedAt      DateTime?

  guide   Guide?  @relation(fields: [guideId], references: [id])
  guideId String?

  @@index([status])
  @@index([guideId])
  @@index([applicantEmail])
  @@index([deletedAt])
}

model Experiment {
  id             String    @id @default(uuid())
  title          String?
  description    String?
  stage          String? // proposed, discussion, accepted, declined
  upvotes        Int       @default(0)
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?
  createdByEmail String? // For CommunityMember creators (since createdById only references Member)

  createdBy   Member?             @relation(fields: [createdById], references: [id])
  createdById String?
  comments    ExperimentComment[]

  @@index([stage])
  @@index([createdByEmail])
  @@index([deletedAt])
}

model ExperimentComment {
  id          String    @id @default(uuid())
  body        String?
  parentId    String?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  authorEmail String? // For CommunityMember commenters (since authorId only references Member)

  experiment   Experiment @relation(fields: [experimentId], references: [id])
  experimentId String
  author       Member?    @relation(fields: [authorId], references: [id])
  authorId     String?

  @@index([experimentId])
  @@index([authorEmail])
  @@index([deletedAt])
}

model Log {
  id        String    @id @default(uuid())
  action    String?
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  actor   Member? @relation(fields: [actorId], references: [id])
  actorId String?

  @@index([action])
  @@index([entity])
  @@index([actorId])
  @@index([deletedAt])
}

model AuditLog {
  id         String    @id @default(uuid())
  action     String // CREATE, UPDATE, DELETE, LOGIN, ETC
  resource   String // Playbook, Member, System
  resourceId String?
  metadata   Json? // Diff, details, etc
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  actor   Member? @relation(fields: [actorId], references: [id])
  actorId String?

  mediaItem   MediaItem? @relation(fields: [mediaItemId], references: [id])
  mediaItemId String?

  @@index([resource, resourceId])
  @@index([actorId])
  @@index([action])
  @@index([deletedAt])
}

model Contribution {
  id                       String    @id @default(uuid())
  type                     String // "event-host", "content", "programs", "internal-works"
  name                     String
  email                    String
  status                   String    @default("pending") // pending, approved, rejected
  eventDate                String?
  eventLocation            String?
  contentUrl               String?
  programId                String?
  internalWorksDescription String?
  submittedAt              DateTime  @default(now())
  deletedAt                DateTime?

  @@index([email])
  @@index([type])
  @@index([status])
  @@index([submittedAt])
  @@index([deletedAt])
}

// Deleted models: Program, Event

model ContentResource {
  id           String  @id @default(uuid())
  title        String
  type         String? // e.g. "Blog", "Video", "Whitepaper"
  status       String  @default("draft")
  customFields Json?   @default("{}")
  content      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  createdBy   Member? @relation(fields: [createdById], references: [id])
  createdById String?

  @@index([type])
  @@index([status])
  @@index([deletedAt])
}

model Project {
  id         String     @id @default(uuid())
  name       String
  status     String     @default("active")
  visibility Visibility @default(CORE)
  // Social/Info
  logo       String? // SVG/Image URL
  website    String?
  twitter    String?
  telegram   String?

  customFields Json?     @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  deletedAt    DateTime?

  createdBy   Member? @relation(fields: [createdById], references: [id])
  createdById String?

  @@index([status])
  @@index([visibility])
  @@index([deletedAt])
}

model Partner {
  id         String     @id @default(uuid())
  name       String
  type       String? // e.g. "Sponsor", "Community", "Vendor"
  status     String     @default("active")
  visibility Visibility @default(CORE)
  // Social/Info
  logo       String?
  website    String?
  twitter    String?
  telegram   String?

  customFields Json?     @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  deletedAt    DateTime?

  createdBy   Member? @relation(fields: [createdById], references: [id])
  createdById String?

  @@index([type])
  @@index([status])
  @@index([visibility])
  @@index([deletedAt])
}

model TableConfig {
  id        String    @id @default(uuid())
  tableName String    @unique // "members", "projects", "partners"
  columns   Json // Array of { id, label, type, width, visible }
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
}

model SystemSettings {
  id        String    @id @default("settings") // Singleton
  key       String    @unique
  value     String
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
}

model Announcement {
  id        String    @id @default(uuid())
  title     String
  link      String?
  audience  String    @default("ALL") // PUBLIC, MEMBER, ALL
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  deletedAt DateTime?
}

model Poll {
  id        String    @id @default(uuid())
  question  String
  options   Json // Array of {id, text, votes}
  status    String    @default("ACTIVE") // ACTIVE, CLOSED
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
}

model MeetingNote {
  id        String    @id @default(uuid())
  content   String    @default("")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
}

model ActionItem {
  id        String    @id @default(uuid())
  text      String
  isDone    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
}

model AttendanceRecord {
  id               String    @id @default(uuid())
  date             DateTime  @default(now())
  presentMemberIds String[] // IDs of members present
  note             String?
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?
}

model RateLimit {
  key       String   @id
  count     Int      @default(0)
  resetAt   BigInt
  deletedAt DateTime?
}

// Added for Push Notifications
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  keys      Json
  userAgent String?
  createdAt DateTime @default(now())
  lastUsed  DateTime @updatedAt
  deletedAt DateTime?

  @@index([userId])
}

model PublicUser {
  id               String   @id @default(uuid())
  email            String   @unique
  fullName         String?
  profileImage     String?
  providerId       String?  // Google ID
  
  // Consent
  consentNewsletter Boolean @default(false)
  consentLegal      Boolean @default(false)
  consentVersion    String?
  consentTimestamp  DateTime?

  // Profile Fields
  bio               String?
  location          String?
  city              String?
  country           String?
  roles             Json?    // Array of strings: "Developer", "Marketing", etc.
  interests         Json?    // Array of strings
  preferredChains   Json?    // Array of strings
  socialProfiles    Json?    // Array of { name: string, url: string }
  skills            Json?    // Array of strings
  currentProject    String?
  availability      String?  // "Open to Hack", "Hiring", etc.

  // Metadata
  signupIp          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt
  deletedAt         DateTime?

  @@index([email])
}
