generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id                      String    @id @default(uuid())
  email                   String    @unique
  xHandle                 String?
  name                    String?
  image                   String?
  permissions             Json?     @default("{\"default\": \"READ\"}")
  tags                    String[]  @default([])
  status                  String // applied, approved, active, paused
  customFields            Json?     @default("{}")
  notificationPreferences Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @default(now()) @updatedAt
  deletedAt               DateTime?

  // Relations
  lockedPlaybooks    Playbook[]          @relation("LockedBy")
  createdPlaybooks   Playbook[]          @relation("CreatedBy")
  assignedOperations Operation[]
  createdMedia       MediaItem[]
  experiments        Experiment[]
  comments           ExperimentComment[]
  mediaComments      Comment[]
  logs               Log[]

  auditLogs        AuditLog[]
  contentResources ContentResource[]
  createdProjects  Project[]
  createdPartners  Partner[]
  guides           Guide[]
  extraProfile     MemberExtraProfile? @relation("MemberExtraProfile")

  @@index([status])
  @@index([xHandle])
  @@index([deletedAt])
  @@index([status, deletedAt])
}

model CommunityMember {
  id                      String    @id @default(uuid())
  email                   String    @unique
  xHandle                 String?
  telegram                String?
  name                    String?
  tags                    String?   @default("member") // e.g. "Founder", "Investor"
  status                  String    @default("active")
  totalXp                 Int       @default(0)
  customFields            Json?     @default("{}")
  notificationPreferences Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @default(now()) @updatedAt
  deletedAt               DateTime?

  extraProfile      MemberExtraProfile? @relation("CommunityMemberExtraProfile")
  bountySubmissions BountySubmission[]

  @@index([status])
  @@index([xHandle])
  @@index([deletedAt])
  @@index([status, deletedAt])
}

model Playbook {
  id             String     @id @default(uuid())
  title          String
  body           Json
  markdownExport String?
  status         String? // draft, pending, approved, published
  visibility     Visibility @default(CORE)
  coverImage     String?
  description    String?
  tags           String[]
  version        Int        @default(1)
  createdAt      DateTime   @default(now())
  deletedAt      DateTime?

  // Relations
  lockedBy    Member?   @relation("LockedBy", fields: [lockedById], references: [id])
  lockedById  String?
  lockedAt    DateTime?
  updatedAt   DateTime  @default(now()) @updatedAt
  createdBy   Member?   @relation("CreatedBy", fields: [createdById], references: [id])
  createdById String?

  @@index([status])
  @@index([visibility])
  @@index([deletedAt])
  @@index([status, deletedAt])
}

model Operation {
  id              String    @id @default(uuid())
  title           String?
  type            String? // task, meeting
  status          String?
  dueDate         DateTime?
  relatedType     String?
  relatedId       String?
  timeEstimate    Int?
  timeLogged      Int?
  calendarEventId String?
  links           String[]
  createdAt       DateTime  @default(now())
  deletedAt       DateTime?

  assignee   Member? @relation(fields: [assigneeId], references: [id])
  assigneeId String?

  @@index([status])
  @@index([type])
  @@index([assigneeId])
  @@index([deletedAt])
  @@index([status, deletedAt])
}

model MediaItem {
  id          String    @id @default(uuid())
  title       String?
  description String?
  platform    String[]
  links       String[]
  status      String? // draft, needs_edit, pending_approval, approved, posted
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  createdBy   Member?     @relation(fields: [createdById], references: [id])
  createdById String?
  posts       MediaPost[]
  comments    Comment[]
  auditLogs   AuditLog[]

  @@index([status])
  @@index([createdById])
  @@index([deletedAt])
  @@index([status, deletedAt])
}

model MediaPost {
  id        String    @id @default(uuid())
  postUrl   String?
  postedAt  DateTime?
  deletedAt DateTime?

  media   MediaItem @relation(fields: [mediaId], references: [id])
  mediaId String
}

model Comment {
  id        String    @id @default(uuid())
  content   String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  media   MediaItem @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId String

  author   Member @relation(fields: [authorId], references: [id])
  authorId String

  @@index([mediaId])
  @@index([deletedAt])
}

enum Visibility {
  CORE
  MEMBER
  PUBLIC
}

model Guide {
  id                   String     @id @default(uuid())
  slug                 String?    @unique
  type                 String? // event, program, content, workshop, hackathon
  title                String?
  coverImage           String?
  body                 Json?
  audience             String[]   @default([])
  formSchema           Json?
  visibility           Visibility @default(CORE)
  maxSubmissionsPublic Int?       @default(1)
  maxSubmissionsMember Int?       @default(10)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @default(now()) @updatedAt
  deletedAt            DateTime?

  createdBy   Member? @relation(fields: [createdById], references: [id])
  createdById String?

  applications Application[]

  @@index([type])
  @@index([visibility])
  @@index([deletedAt])
}

model Application {
  id             String    @id @default(uuid())
  applicantEmail String?
  data           Json?
  status         String?
  submittedAt    DateTime  @default(now())
  deletedAt      DateTime?

  guide   Guide?  @relation(fields: [guideId], references: [id])
  guideId String?

  @@index([status])
  @@index([guideId])
  @@index([applicantEmail])
  @@index([deletedAt])
}

model Experiment {
  id             String    @id @default(uuid())
  title          String?
  description    String?
  stage          String? // proposed, discussion, accepted, declined
  upvotes        Int       @default(0)
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?
  createdByEmail String? // For CommunityMember creators (since createdById only references Member)

  createdBy   Member?             @relation(fields: [createdById], references: [id])
  createdById String?
  comments    ExperimentComment[]

  @@index([stage])
  @@index([createdByEmail])
  @@index([deletedAt])
}

model ExperimentComment {
  id          String    @id @default(uuid())
  body        String?
  parentId    String?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  authorEmail String? // For CommunityMember commenters (since authorId only references Member)

  experiment   Experiment @relation(fields: [experimentId], references: [id])
  experimentId String
  author       Member?    @relation(fields: [authorId], references: [id])
  authorId     String?

  @@index([experimentId])
  @@index([authorEmail])
  @@index([deletedAt])
}

model Log {
  id        String    @id @default(uuid())
  action    String?
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  actor   Member? @relation(fields: [actorId], references: [id])
  actorId String?

  @@index([action])
  @@index([entity])
  @@index([actorId])
  @@index([deletedAt])
}

model AuditLog {
  id         String    @id @default(uuid())
  action     String // CREATE, UPDATE, DELETE, LOGIN, ETC
  resource   String // Playbook, Member, System
  resourceId String?
  metadata   Json? // Diff, details, etc
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  actor   Member? @relation(fields: [actorId], references: [id])
  actorId String?

  mediaItem   MediaItem? @relation(fields: [mediaItemId], references: [id])
  mediaItemId String?

  @@index([resource, resourceId])
  @@index([actorId])
  @@index([action])
  @@index([deletedAt])
}

model Contribution {
  id                       String    @id @default(uuid())
  type                     String // "event-host", "content", "programs", "internal-works", "quest-fullstack", "quest-creator", "quest-builder"
  name                     String
  email                    String
  status                   String    @default("pending") // pending, approved, rejected
  eventDate                String?
  eventLocation            String?
  contentUrl               String?
  programId                String?
  internalWorksDescription String?
  links                    Json? // Array of { label, url } for quest submissions
  submittedAt              DateTime  @default(now())
  deletedAt                DateTime?

  @@index([email])
  @@index([type])
  @@index([status])
  @@index([submittedAt])
  @@index([deletedAt])
}

// Deleted models: Program, Event

model ContentResource {
  id           String  @id @default(uuid())
  title        String
  type         String? // e.g. "Blog", "Video", "Whitepaper"
  status       String  @default("draft")
  customFields Json?   @default("{}")
  content      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  createdBy   Member? @relation(fields: [createdById], references: [id])
  createdById String?

  @@index([type])
  @@index([status])
  @@index([deletedAt])
}

model Project {
  id         String     @id @default(uuid())
  name       String
  status     String     @default("active")
  visibility Visibility @default(CORE)
  // Social/Info
  logo       String? // SVG/Image URL
  website    String?
  twitter    String?
  telegram   String?

  customFields Json?     @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  deletedAt    DateTime?

  createdBy   Member? @relation(fields: [createdById], references: [id])
  createdById String?

  @@index([status])
  @@index([visibility])
  @@index([deletedAt])
}

model Partner {
  id         String     @id @default(uuid())
  name       String
  type       String? // e.g. "Sponsor", "Community", "Vendor"
  status     String     @default("active")
  visibility Visibility @default(CORE)
  // Social/Info
  logo       String?
  website    String?
  twitter    String?
  telegram   String?

  customFields Json?     @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  deletedAt    DateTime?

  createdBy   Member? @relation(fields: [createdById], references: [id])
  createdById String?

  @@index([type])
  @@index([status])
  @@index([visibility])
  @@index([deletedAt])
}

model TableConfig {
  id        String    @id @default(uuid())
  tableName String    @unique // "members", "projects", "partners"
  columns   Json // Array of { id, label, type, width, visible }
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
}

model SystemSettings {
  id        String    @id @default("settings") // Singleton
  key       String    @unique
  value     String
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
}

model Announcement {
  id        String    @id @default(uuid())
  title     String
  link      String?
  audience  String    @default("ALL") // PUBLIC, MEMBER, ALL
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  deletedAt DateTime?
}

model Poll {
  id        String    @id @default(uuid())
  question  String
  options   Json // Array of {id, text, votes}
  status    String    @default("ACTIVE") // ACTIVE, CLOSED
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
}

model MeetingNote {
  id        String    @id @default(uuid())
  content   String    @default("")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
}

model ActionItem {
  id        String    @id @default(uuid())
  text      String
  isDone    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
}

model AttendanceRecord {
  id               String    @id @default(uuid())
  date             DateTime  @default(now())
  presentMemberIds String[] // IDs of members present
  note             String?
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?
}

model RateLimit {
  key       String    @id
  count     Int       @default(0)
  resetAt   BigInt
  deletedAt DateTime?
}

// Added for Push Notifications
model PushSubscription {
  id        String    @id @default(uuid())
  userId    String
  endpoint  String    @unique
  keys      Json
  userAgent String?
  createdAt DateTime  @default(now())
  lastUsed  DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
}

model PublicUser {
  id           String  @id @default(uuid())
  email        String  @unique
  fullName     String?
  profileImage String?
  providerId   String? // Google ID

  // Consent
  consentNewsletter Boolean   @default(false)
  consentLegal      Boolean   @default(false)
  consentVersion    String?
  consentTimestamp  DateTime?

  // Profile Fields
  bio             String?
  location        String?
  city            String?
  country         String?
  roles           Json? // Array of strings: "Developer", "Marketing", etc.
  interests       Json? // Array of strings
  preferredChains Json? // Array of strings
  socialProfiles  Json? // Array of { name: string, url: string }
  skills          Json? // Array of strings
  currentProject  String?
  availability    String? // "Open to Hack", "Hiring", etc.

  // Metadata
  signupIp  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  bountySubmissions BountySubmission[]

  @@index([email])
}

// Extra profile fields for CORE/MEMBER users (member profile page)
model MemberExtraProfile {
  id                String  @id @default(uuid())
  memberId          String? @unique
  communityMemberId String? @unique

  // Public-style profile fields
  availability   String?
  currentProject String?
  city           String?
  country        String?
  roles          Json? // Array of strings (max 3 enforced in app)
  interests      Json? // Array of strings
  skills         Json? // Array of strings
  socialProfiles Json? // Array of { name: string, url: string }

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  member          Member?          @relation("MemberExtraProfile", fields: [memberId], references: [id])
  communityMember CommunityMember? @relation("CommunityMemberExtraProfile", fields: [communityMemberId], references: [id])

  @@index([memberId])
  @@index([communityMemberId])
  @@index([deletedAt])
}

model Bounty {
  id             String    @id @default(uuid())
  title          String
  description    String?
  type           String // "tweet", "thread", "blog", "video", "developer"
  xpReward       Int       @default(10)
  pointsReward   Int       @default(10) // NEW: points awarded on approval
  frequency      String // "daily", "twice-weekly", "weekly", "biweekly"
  audience       String    @default("all") // "all", "member", "public"
  status         String    @default("active") // "active", "paused", "closed"
  deadline       DateTime?
  maxPerCycle    Int? // Max submissions per member per cycle
  maxSubmissions Int? // NEW: total max submissions across all users
  brief          String? // NEW: detailed brief / instructions
  resources      Json? // NEW: array of { label, url } resource links
  rules          String? // NEW: submission rules / requirements
  cash           Int? // NEW: optional cash reward (in INR)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt
  deletedAt      DateTime?

  submissions BountySubmission[]

  @@index([type])
  @@index([status])
  @@index([audience])
  @@index([deletedAt])
}

model BountySubmission {
  id               String  @id @default(uuid())
  proofUrl         String
  proofNote        String?
  status           String  @default("pending") // "pending", "approved", "rejected"
  reviewNote       String?
  xpAwarded        Int?
  pointsAwarded    Int? // NEW: points awarded on approval
  submissionNumber Int? // NEW: sequential number for this bounty

  bounty   Bounty @relation(fields: [bountyId], references: [id])
  bountyId String

  submittedBy      CommunityMember? @relation(fields: [submittedById], references: [id])
  submittedById    String?
  publicUser       PublicUser?      @relation(fields: [publicUserId], references: [id])
  publicUserId     String?
  submittedByEmail String
  reviewedById     String?

  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?
  deletedAt   DateTime?

  @@index([bountyId])
  @@index([submittedById])
  @@index([publicUserId])
  @@index([submittedByEmail])
  @@index([status])
  @@index([deletedAt])
}

model LumaEvent {
  id         String    @id @default(uuid())
  apiId      String    @unique
  name       String
  startAt    DateTime
  endAt      DateTime?
  coverUrl   String?
  url        String
  timezone   String?
  visibility String    @default("public")
  city       String?
  geoData    Json?
  hostName   String?
  hostEmail  String?
  hosts      Json?
  syncedAt   DateTime  @default(now())
  createdAt  DateTime  @default(now())

  @@index([startAt])
  @@index([visibility])
}

// PII Vault — stores encrypted personal data with HMAC search index
model PersonalVault {
  id             String  @id @default(uuid())
  entityType     String // "Member", "CommunityMember", "PublicUser"
  entityId       String // ID of the related record
  fieldName      String // "email", "name", "phone", etc.
  encryptedValue String // AES-256-GCM encrypted value
  hmacIndex      String? // HMAC-SHA256 hash for searching (e.g., email lookup)
  keyVersion     Int     @default(1) // for future key rotation

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([entityType, entityId, fieldName])
  @@index([entityType, entityId])
  @@index([hmacIndex])
  @@index([entityType, fieldName, hmacIndex])
}

// In-app notifications
model Notification {
  id        String   @id @default(uuid())
  userEmail String // recipient
  type      String // "quest_approved", "bounty_approved", "team_invite", etc.
  title     String
  message   String
  link      String? // clickable destination, e.g. "/member/bounty"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userEmail, isRead, createdAt])
  @@index([userEmail, createdAt])
}

// Dual Currency Wallet (XP + Points)
model UserWallet {
  id            String   @id @default(uuid())
  userEmail     String   @unique
  totalXp       Int      @default(0) // lifetime XP (never decreases)
  pointsBalance Int      @default(0) // spendable points (can decrease)
  totalEarned   Int      @default(0) // lifetime points earned
  totalSpent    Int      @default(0) // lifetime points spent
  totalExpired  Int      @default(0) // lifetime points expired
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  batches      PointsBatch[]
  transactions WalletTransaction[]

  @@index([totalXp]) // leaderboard sort
}

model PointsBatch {
  id        String   @id @default(uuid())
  walletId  String
  amount    Int // original amount
  remaining Int // how much is left (decreases on spend/expire)
  source    String // "quest", "bounty", "admin_adjust", "challenge_winner"
  sourceId  String? // quest ID, bounty ID, etc.
  earnedAt  DateTime @default(now())
  expiresAt DateTime // when this batch expires

  wallet UserWallet @relation(fields: [walletId], references: [id])

  @@index([walletId, expiresAt])
  @@index([expiresAt, remaining]) // expiry cron
}

model WalletTransaction {
  id           String   @id @default(uuid())
  walletId     String
  pointsAmount Int // positive = earn, negative = spend
  xpAmount     Int // XP earned (always >= 0)
  type         String // "quest_reward", "bounty_reward", "swag_purchase", "admin_adjust", "expiry"
  description  String?
  sourceId     String? // related entity ID
  createdAt    DateTime @default(now())

  wallet UserWallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@index([type])
}

// Quest System
model Quest {
  id               String    @id @default(uuid())
  title            String
  description      String?
  type             String // "daily", "weekly", "one-time", "recurring"
  category         String? // "social", "developer", "community", "content"
  xpReward         Int       @default(10)
  pointsReward     Int       @default(10)
  audience         String    @default("all") // "all", "member", "public"
  status           String    @default("active") // "active", "paused", "closed"
  maxCompletions   Int? // null = unlimited
  totalCompletions Int       @default(0)
  proofRequired    Boolean   @default(true)
  proofDescription String? // "Submit a screenshot of your tweet"
  startDate        DateTime?
  endDate          DateTime?
  createdBy        String // admin email
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt
  deletedAt        DateTime?

  completions QuestCompletion[]

  @@index([status])
  @@index([audience])
  @@index([type])
  @@index([deletedAt])
  @@index([status, audience, deletedAt])
}

model QuestCompletion {
  id            String    @id @default(uuid())
  questId       String
  userEmail     String
  proofUrl      String?
  proofNote     String?
  status        String    @default("pending") // "pending", "approved", "rejected"
  reviewNote    String?
  reviewedBy    String? // admin email
  xpAwarded     Int?
  pointsAwarded Int?
  submittedAt   DateTime  @default(now())
  reviewedAt    DateTime?

  quest Quest @relation(fields: [questId], references: [id])

  @@unique([questId, userEmail]) // one completion per quest per user (for one-time quests)
  @@index([questId])
  @@index([userEmail])
  @@index([status])
  @@index([questId, status])
}

// Swag Shop
model SwagItem {
  id             String    @id @default(uuid())
  name           String
  description    String?
  image          String? // cover image URL
  images         Json? // array of image URLs
  pointsCost     Int // points required to redeem
  category       String? // "tshirt", "sticker", "hoodie", "accessory"
  audience       String    @default("all") // "all", "member"
  totalStock     Int       @default(0)
  remainingStock Int       @default(0)
  status         String    @default("active") // "active", "paused", "out_of_stock"
  featured       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt
  deletedAt      DateTime?

  variants SwagVariant[]
  orders   SwagOrder[]

  @@index([status])
  @@index([audience])
  @@index([category])
  @@index([deletedAt])
}

model SwagVariant {
  id        String   @id @default(uuid())
  itemId    String
  label     String // "S", "M", "L", "XL", "Red", "Blue"
  stock     Int      @default(0)
  createdAt DateTime @default(now())

  item SwagItem @relation(fields: [itemId], references: [id])

  @@index([itemId])
}

model SwagOrder {
  id              String   @id @default(uuid())
  itemId          String
  variantId       String?
  userEmail       String
  pointsSpent     Int
  quantity        Int      @default(1)
  status          String   @default("pending") // "pending", "processing", "shipped", "delivered", "cancelled"
  trackingNumber  String?
  trackingUrl     String?
  shippingAddress String? // encrypted via PII vault reference
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  item SwagItem @relation(fields: [itemId], references: [id])

  @@index([userEmail])
  @@index([status])
  @@index([itemId])
}

// ===== USER PROJECTS =====

model UserProject {
  id           String    @id @default(uuid())
  title        String
  slug         String    @unique
  description  String?
  coverImage   String?
  images       Json? // array of image URLs
  demoUrl      String?
  repoUrl      String?
  techStack    String[]  @default([])
  tags         String[]  @default([])
  teamEmails   String[]  @default([]) // all team member emails
  ownerEmail   String // creator
  viewCount    Int       @default(0)
  likeCount    Int       @default(0)
  commentCount Int       @default(0)
  status       String    @default("published") // "draft", "published", "hidden", "reported"
  version      Int       @default(1) // optimistic locking
  privacy      Json? // { showTeam: true, showRepo: true }
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  deletedAt    DateTime?

  versions ProjectVersion[]
  comments ProjectComment[]
  likes    ProjectLike[]

  @@index([ownerEmail])
  @@index([slug])
  @@index([status])
  @@index([deletedAt])
}

model ProjectVersion {
  id          String   @id @default(uuid())
  projectId   String
  versionNum  Int
  title       String
  description String?
  changes     String? // what changed in this version
  snapshot    Json? // snapshot of project data at this version
  createdBy   String // email of editor
  createdAt   DateTime @default(now())

  project UserProject @relation(fields: [projectId], references: [id])

  @@index([projectId, versionNum])
}

model ProjectComment {
  id          String    @id @default(uuid())
  projectId   String
  authorEmail String
  content     String
  isHidden    Boolean   @default(false) // owner can hide
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  project UserProject @relation(fields: [projectId], references: [id])

  @@index([projectId, createdAt])
  @@index([authorEmail])
  @@index([deletedAt])
}

model ProjectLike {
  id        String   @id @default(uuid())
  projectId String
  userEmail String
  createdAt DateTime @default(now())

  project UserProject @relation(fields: [projectId], references: [id])

  @@unique([projectId, userEmail])
  @@index([projectId])
  @@index([userEmail])
}

model ShowcaseSection {
  id          String   @id @default(uuid())
  title       String
  description String?
  projectIds  String[] @default([]) // ordered list of project IDs
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([sortOrder])
}

// ===== SPEEDRUN =====

model SpeedrunRun {
  id                   String    @id @default(uuid())
  slug                 String    @unique // e.g. "may-2026"
  monthLabel           String // e.g. "MAY 2026"
  theme                String? // null until announced
  status               String    @default("upcoming") // upcoming, registration_open, in_progress, completed, cancelled
  startDate            DateTime?
  endDate              DateTime?
  registrationDeadline DateTime?
  isCurrent            Boolean   @default(false) // exactly one row should be true
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @default(now()) @updatedAt
  deletedAt            DateTime?

  registrations SpeedrunRegistration[]
  teams         SpeedrunTeam[]

  @@index([status])
  @@index([isCurrent])
  @@index([deletedAt])
}

model SpeedrunTeam {
  id           String   @id @default(uuid())
  runId        String
  name         String
  code         String   @unique // e.g. "TM-7XK2QP" — invite code for teammates
  captainEmail String
  createdAt    DateTime @default(now())

  run           SpeedrunRun            @relation(fields: [runId], references: [id], onDelete: Cascade)
  members       SpeedrunTeamMember[]
  registrations SpeedrunRegistration[]

  @@index([runId])
  @@index([code])
  @@index([captainEmail])
}

model SpeedrunTeamMember {
  id       String   @id @default(uuid())
  teamId   String
  email    String
  role     String   @default("member") // captain, member
  joinedAt DateTime @default(now())

  team SpeedrunTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, email])
  @@index([teamId])
  @@index([email])
}

model SpeedrunRegistration {
  id              String   @id @default(uuid())
  runId           String
  teamId          String? // null for solo
  userEmail       String
  fullName        String
  phone           String?
  city            String?
  twitterHandle   String?
  githubHandle    String?
  primaryRole     String // Builder, Designer, PM, Other
  techStack       String[] @default([])
  experience      String // beginner, intermediate, advanced
  teamMode        String // solo, create, join
  trackPreference String?
  projectIdea     String?
  whyJoin         String?
  consent         Boolean  @default(false)
  status          String   @default("registered") // registered, confirmed, withdrawn, rejected
  adminNotes      String?
  // Referral attribution
  referralCode    String? // links to SpeedrunReferralCode.code (denormalized for fast filter)
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  run      SpeedrunRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  team     SpeedrunTeam?         @relation(fields: [teamId], references: [id])
  referrer SpeedrunReferralCode? @relation(fields: [referralCode], references: [code])

  @@unique([runId, userEmail])
  @@index([runId])
  @@index([teamId])
  @@index([userEmail])
  @@index([status])
  @@index([referralCode])
}

// One referral code per user. Code is shareable: /r/{code}
model SpeedrunReferralCode {
  id          String   @id @default(uuid())
  code        String   @unique // e.g. "RF-7XK2QP" — short shareable identifier
  userEmail   String   @unique // referrer's email (one code per user across all runs)
  clicks      Int      @default(0)
  conversions Int      @default(0) // count of registrations that used this code
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  registrations SpeedrunRegistration[]

  @@index([code])
  @@index([userEmail])
}

// ===== ANALYTICS =====

model AnalyticsEvent {
  id          String   @id @default(uuid())
  type        String // page_view, click, api_call, custom
  name        String // "quest_completed", "event_card_click", etc.
  path        String? // URL path
  referrer    String?
  userEmail   String? // null for anonymous
  sessionId   String // cookie-less UUID per visit
  data        Json? // { questId, challengeId, durationMs, etc. }
  device      String? // mobile, desktop, tablet
  browser     String?
  os          String?
  country     String? // from Vercel geo headers
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  createdAt   DateTime @default(now())

  @@index([type, createdAt])
  @@index([name, createdAt])
  @@index([path, createdAt])
  @@index([userEmail])
  @@index([sessionId])
}

model AnalyticsDailyStat {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  metric    String // "page_views", "unique_visitors", "quest_completions", etc.
  value     Int
  breakdown Json? // { "/public": 450, "/public/bounty": 120 }

  @@unique([date, metric])
  @@index([date])
}

model ApiHealthLog {
  id         String   @id @default(uuid())
  endpoint   String
  method     String
  statusCode Int
  durationMs Int
  error      String?
  userEmail  String?
  createdAt  DateTime @default(now())

  @@index([endpoint, createdAt])
  @@index([statusCode, createdAt])
}

// ===== TWO-FACTOR AUTHENTICATION =====

model TwoFactorAuth {
  id             String    @id @default(uuid())
  userEmail      String    @unique
  totpSecret     String? // encrypted via PII vault pattern
  totpEnabled    Boolean   @default(false)
  totpVerifiedAt DateTime?
  passkeyEnabled Boolean   @default(false)
  recoveryCodes  String? // encrypted, comma-separated
  recoveryUsed   String[]  @default([])
  backupEmail    String? // encrypted
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  passkeys Passkey[]

  @@index([userEmail])
}

model Passkey {
  id           String    @id @default(uuid())
  twoFactorId  String
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt
  deviceName   String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  twoFactor TwoFactorAuth @relation(fields: [twoFactorId], references: [id])

  @@index([twoFactorId])
}
